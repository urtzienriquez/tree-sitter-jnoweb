{
  "name": "tree-sitter-jnoweb",
  "version": "0.2.0",
  "description": "Tree-sitter parser for jnoweb (Julia NoWeb) literate programming documents",
  "main": "bindings/node",
  "scripts": {
    "test": "tree-sitter test",
    "build": "tree-sitter build --wasm",
    "install": "node-gyp rebuild"
  },
  "keywords": [
    "jnoweb",
    "julia",
    "tree-sitter",
    "parser",
    "incremental"
  ],
  "author": "Urtzi",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/urtzienriquez/tree-sitter-jnoweb.git"
  },
  "bugs": {
    "url": "https://github.com/urtzienriquez/tree-sitter-jnoweb/issues"
  },
  "homepage": "https://github.com/urtzienriquez/tree-sitter-jnoweb",
  "dependencies": {
    "nan": "^2.15.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.24.0"
  },
  "files": [
    "grammar.js",
    "binding.gyp",
    "bindings/node/*",
    "Cargo.toml",
    "bindings/rust/*",
    "queries/*",
    "src/*",
    "tree-sitter.json",
    "tree-sitter-jnoweb.wasm"
  ]
